rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      let data = getUserData();
      return isSignedIn() && (
        (data != null && data.role == 'admin') ||
        request.auth.token.email == 'blommaavmystik@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isUser(userId) || isAdmin();
      allow create: if isUser(userId) && 
                    incoming().keys().hasAll(['userId', 'email', 'role', 'createdAt']) &&
                    incoming().keys().size() == 4 &&
                    incoming().userId == userId &&
                    incoming().role in ['admin', 'client'] &&
                    incoming().createdAt == request.time;
      allow update: if isUser(userId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['email', 'updatedAt']) &&
                    incoming().updatedAt == request.time;
    }

    // --- Projects ---
    function isValidProject(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.heroImage is string && data.heroImage.size() <= 1000 &&
             data.images is list && data.images.size() <= 50;
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProject(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidProject(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasAny(['title', 'category', 'year', 'location', 'description', 'concept', 'heroImage', 'images', 'plans', 'sections', 'facts', 'credits', 'updatedAt'])
      ) && incoming().updatedAt == request.time;
      allow delete: if isAdmin();
    }

    // --- News ---
    function isValidNews(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.date is string && data.date.size() <= 50 &&
             data.category is string && data.category.size() <= 100 &&
             data.description is string && data.description.size() <= 5000;
    }

    match /news/{newsId} {
      allow read: if true;
      allow create: if isAdmin() && isValidNews(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidNews(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasAny(['title', 'date', 'category', 'description', 'updatedAt']) &&
                    incoming().updatedAt == request.time;
      allow delete: if isAdmin();
    }

    // --- Settings ---
    match /settings/{settingId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // Default Deny (moved to end)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
